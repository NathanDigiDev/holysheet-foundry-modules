<section class="holysheet-npc">
  <header class="hs-npc-head">
    <div class="hs-portrait-ring">
      <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" style="{{hs.portrait.style}}" />
    </div>
    <div class="hs-npc-id">
      <input class="hs-name hs-name-{{hs.nameSize}}" name="name" type="text" value="{{actor.name}}" placeholder="{{localize "HOLYSHEET.Placeholder.NpcName"}}" />

      {{#if hs.modules.resources}}
      <section class="hs-resource-orbs">
        <label class="hs-resource-orb">
          <input name="system.resources.pv.value" type="number" value="{{system.resources.pv.value}}" min="0" />
          <small>/<input name="system.resources.pv.max" type="number" value="{{system.resources.pv.max}}" min="0" /></small>
          <span>{{localize "HOLYSHEET.Label.Pv"}}</span>
        </label>
        {{#if hs.modules.armor}}
        <label class="hs-armor-orb" title="{{localize "HOLYSHEET.Label.Armor"}}">
          <i class="fa-solid fa-shield-halved"></i>
          <strong>{{hs.armorTotal}}</strong>
        </label>
        {{/if}}
      </section>
      {{/if}}
    </div>
  </header>

  {{#if hs.modules.aptitudes}}
  <section class="hs-banner-aptitudes" aria-label="{{localize "HOLYSHEET.Label.Aptitudes"}}">
    {{#each hs.aptitudes}}
    <article class="hs-aptitude-card" title="{{description}}">
      <input name="{{field}}" type="number" value="{{value}}" min="1" max="100" />
      <button type="button" data-roll="aptitude" data-roll-group="aptitude" data-roll-key="{{key}}" data-roll-label="{{label}}" data-roll-target="{{value}}" data-roll-modifier="{{modifier}}">
        <span>{{abbreviation}}</span>
      </button>
    </article>
    {{/each}}
  </section>
  {{/if}}

  {{#if hs.modules.customStates}}
  {{#if hs.customStates.length}}
  <section class="hs-custom-states" aria-label="{{localize "HOLYSHEET.Label.States"}}">
    {{#each hs.customStates}}
    {{#if isGauge}}
    <label class="hs-state-gauge" title="{{description}}" style="--hs-state-color: {{color}}; --hs-state-fill: {{percent}}%;">
      {{#if icon}}<img src="{{icon}}" alt="" />{{else}}<i class="fa-solid fa-circle-dot"></i>{{/if}}
      <span class="hs-state-gauge-track">
        <span data-readout="{{value}} / {{max}}">{{#if hasName}}{{name}}{{/if}}</span>
        <input type="range" name="{{valueField}}" value="{{value}}" min="0" max="{{max}}" data-state-value="{{key}}" />
      </span>
    </label>
    {{else}}
    <button type="button" class="hs-state-token {{#if checked}}active{{/if}}" data-toggle-state="{{key}}" title="{{description}}" style="--hs-state-color: {{color}};">
      {{#if icon}}<img src="{{icon}}" alt="" />{{/if}}
    </button>
    {{/if}}
    {{/each}}
  </section>
  {{/if}}
  {{/if}}

  <section class="hs-panel">
    <h2>{{localize "HOLYSHEET.Label.Description"}}</h2>
    <textarea name="system.description" rows="6">{{system.description}}</textarea>
  </section>

  {{#if hs.modules.inventory}}
  <section class="hs-panel">
    <h2>
      {{localize "HOLYSHEET.Label.Inventory"}}
      <button type="button" data-create-equipment>+</button>
    </h2>
    {{#each hs.inventoryGroups}}
    <section class="hs-inventory-group">
      <h3>{{category}}</h3>
      {{#each items}}
      <div class="hs-list-row hs-inventory-row">
        <span class="hs-item-image">
          {{#if img}}<img src="{{img}}" alt="" />{{/if}}
        </span>
        {{#if system.equipable}}
        <input class="hs-equip-toggle" type="checkbox" data-toggle-equipment="{{id}}" {{checked system.equipped}} title="{{localize "HOLYSHEET.Action.Equip"}}" />
        {{else}}
        <span class="hs-equip-placeholder"></span>
        {{/if}}
        <span class="hs-item-name">
          {{name}}
          {{#if system.armorValue}}
          <span class="hs-armor-badge" title="{{localize "HOLYSHEET.Label.Armor"}}"><i class="fa-solid fa-shield"></i> {{system.armorValue}}</span>
          {{/if}}
        </span>
        <span class="hs-item-quantity">
          <button type="button" data-adjust-quantity="{{id}}" data-delta="-1" title="{{localize "HOLYSHEET.Action.RemoveOne"}}">-</button>
          <strong>{{system.quantity}}</strong>
          <button type="button" data-adjust-quantity="{{id}}" data-delta="1" title="{{localize "HOLYSHEET.Action.AddOne"}}">+</button>
        </span>
        <button type="button" class="hs-icon-button" data-item-id="{{id}}" title="{{localize "HOLYSHEET.Action.Edit"}}"><i class="fa-solid fa-pen-to-square"></i></button>
        <button type="button" class="hs-icon-button" data-delete-equipment="{{id}}" title="{{localize "HOLYSHEET.Action.Delete"}}"><i class="fa-solid fa-trash"></i></button>
      </div>
      {{/each}}
    </section>
    {{/each}}
  </section>
  {{/if}}
</section>
