<div class="holysheet hs-theme-cuir">
<div class="hcc-app hcc-calendar">
  {{#if isListMode}}
    <header class="hcc-header">
      <div>
        <h2>{{localize "HCC.CalendarsTitle"}}</h2>
        <p>{{localize "HCC.CalendarsHint"}}</p>
      </div>
      <div class="hcc-header-actions">
        <button type="button" data-action="show-widget"><i class="fa-solid fa-eye"></i></button>
        {{#if isGM}}
          <button type="button" data-action="add-calendar"><i class="fa-solid fa-plus"></i></button>
        {{/if}}
      </div>
    </header>

    <section class="hcc-calendar-list">
      {{#each calendars}}
        <article class="hcc-calendar-card {{#if active}}active{{/if}}">
          <label class="hcc-active-choice">
            <input type="checkbox" data-action="activate-calendar" data-value="{{id}}" {{#if active}}checked{{/if}} {{#unless ../isGM}}disabled{{/unless}}>
            <span>{{localize "HCC.Active"}}</span>
          </label>
          <button type="button" class="hcc-calendar-card-main" data-action="summary-calendar" data-value="{{id}}">
            <strong>{{name}}</strong>
            <span>{{dateLabel}}</span>
            {{#if zoneName}}<small>{{zoneName}}</small>{{/if}}
          </button>
          {{#if ../isGM}}
            <div class="hcc-calendar-card-actions">
              <button type="button" data-action="configure-calendar" data-value="{{id}}" data-tooltip="{{localize 'HCC.Edit'}}"><i class="fa-solid fa-gear"></i></button>
              <button type="button" data-action="duplicate-calendar" data-value="{{id}}" data-tooltip="{{localize 'HCC.Duplicate'}}"><i class="fa-solid fa-copy"></i></button>
            </div>
          {{/if}}
        </article>
      {{/each}}
    </section>
  {{/if}}

  {{#if isSummaryMode}}
    <header class="hcc-header">
      <div>
        <h2>{{calendar.name}}</h2>
        <p>{{currentDateLabel}}</p>
        {{#if description}}<p>{{description}}</p>{{/if}}
      </div>
      <div class="hcc-header-actions">
        <button type="button" data-action="show-list"><i class="fa-solid fa-list"></i></button>
        <button type="button" data-action="view-calendar" data-value="{{calendar.id}}"><i class="fa-solid fa-calendar-days"></i> {{localize "HCC.MonthView"}}</button>
        {{#if isGM}}
          <button type="button" data-action="configure"><i class="fa-solid fa-gears"></i></button>
        {{/if}}
      </div>
    </header>

    <section class="hcc-summary-grid">
      <article>
        <h3>{{localize "HCC.CurrentDate"}}</h3>
        <strong>{{currentDateLabel}}</strong>
        {{#if season}}<span>{{season}} - {{zone.name}}</span>{{else}}<span>{{zone.name}}</span>{{/if}}
      </article>
      <article>
        <h3>{{localize "HCC.Structure"}}</h3>
        <span>{{localize "HCC.MonthsCount" count=monthsCount}}</span>
        <span>{{localize "HCC.WeekdaysCount" count=weekdaysCount}}</span>
      </article>
      <article>
        <h3>{{localize "HCC.Events"}}</h3>
        <span>{{localize "HCC.FixedEventsCount" count=eventsCount}}</span>
      </article>
    </section>

    <section class="hcc-section">
      <h3>{{localize "HCC.FixedEvents"}}</h3>
      <div class="hcc-summary-events">
        {{#if events.length}}
          {{#each events}}
            <div>
              <i class="fa-solid fa-star"></i>
              <strong>{{name}}</strong>
              <span>{{day}} {{monthName}}</span>
            </div>
          {{/each}}
        {{else}}
          <p>{{localize "HCC.NoFixedEvents"}}</p>
        {{/if}}
      </div>
    </section>
  {{/if}}

  {{#if isMonthMode}}
    <header class="hcc-header">
      <div>
        <h2>{{calendar.name}}</h2>
        <p>{{localize "HCC.CurrentDate"}}: {{currentDateLabel}}</p>
        {{#if season}}<p>{{season}} - {{zone.name}}</p>{{/if}}
      </div>
      <div class="hcc-header-actions">
        <button type="button" data-action="show-list"><i class="fa-solid fa-list"></i></button>
        <button type="button" data-action="show-widget"><i class="fa-solid fa-eye"></i></button>
        {{#if isGM}}
          <button type="button" data-action="configure"><i class="fa-solid fa-gears"></i></button>
          <button type="button" data-action="advance-day">{{localize "HCC.AdvanceOneDay"}}</button>
        {{/if}}
      </div>
    </header>

    {{#if isGM}}
      <form class="hcc-advance" data-advance-form>
        <label>
          {{localize "HCC.AdvanceDays"}}
          <input type="number" name="days" min="0" value="1">
        </label>
        <label>
          {{localize "HCC.TargetPhase"}}
          <select name="phaseId">
            {{#each phases}}
              <option value="{{id}}">{{label}}</option>
            {{/each}}
          </select>
        </label>
        <button type="submit">{{localize "HCC.AdvanceTime"}}</button>
      </form>
    {{/if}}

    <nav class="hcc-month-nav">
      <button type="button" data-action="previous-month"><i class="fa-solid fa-chevron-left"></i></button>
      <h3>{{month.name}} {{year}}</h3>
      <button type="button" data-action="next-month"><i class="fa-solid fa-chevron-right"></i></button>
    </nav>

    <section class="hcc-month-grid" style="--hcc-weekdays: {{weekdaysCount}}">
      {{#each calendar.weekdays}}
        <strong class="hcc-weekday">{{this}}</strong>
      {{/each}}
      {{#each cells}}
        {{#if empty}}
          <span class="hcc-day empty"></span>
        {{else}}
        <button type="button" class="hcc-day{{#if isToday}} today{{/if}}{{#if isSelected}} selected{{/if}}" data-action="select-day" data-value="{{day}}">
          <span>{{day}}</span>
          <small>{{weekday}}</small>
          {{#if events.length}}
            <i class="fa-solid fa-star hcc-event-marker" data-tooltip="{{localize 'HCC.EventsTooltip' count=events.length}}"></i>
          {{/if}}
          {{#if hasNote}}<span class="hcc-note-dot"></span>{{/if}}
        </button>
      {{/if}}
      {{/each}}
    </section>

    <section class="hcc-day-panel">
      <h3>{{selectedDateLabel}}</h3>
      <div class="hcc-notes">
        {{#if notes.length}}
          {{#each notes}}
            <button type="button" data-action="open-note" data-value="{{id}}">
              <i class="fa-solid fa-book-open"></i>
              {{name}}
            </button>
          {{/each}}
        {{else}}
          <p>{{localize "HCC.NoNotes"}}</p>
        {{/if}}
      </div>

      <form class="hcc-note-form" data-note-form>
        <h4>{{localize "HCC.CreateNote"}}</h4>
        <label>
          {{localize "HCC.NoteTitle"}}
          <input type="text" name="title" required>
        </label>
        <label>
          {{localize "HCC.DayPhase"}}
          <select name="phaseId">
            {{#each phases}}
              <option value="{{id}}">{{label}}</option>
            {{/each}}
          </select>
        </label>
        <label>
          {{localize "HCC.NoteVisibility"}}
          <select name="visibility">
            {{#each visibilities}}
              <option value="{{id}}">{{label}}</option>
            {{/each}}
          </select>
        </label>
        <label class="hcc-full">
          {{localize "HCC.NoteContent"}}
          <textarea name="content" rows="4"></textarea>
        </label>
        <button type="submit">{{localize "HCC.Save"}}</button>
      </form>
    </section>
  {{/if}}
</div>
</div>
